# FPL bearer token – server-side fallback used when the browser does not send
# an X-Fpl-Token header (e.g. for scripted / server-side access).
# Required only if you do not set the token via the in-app Settings panel.
FPL_BEARER_TOKEN=

# football-data.org API key – enables the Premier League standings widget.
# Leave empty to use stub data.
FOOTBALL_DATA_API_KEY=

# Comma-separated list of allowed frontend origins.
# Leave empty (or unset) for local development to allow all origins.
# Example: https://my-app.vercel.app,https://www.my-app.com
ALLOWED_ORIGINS=
