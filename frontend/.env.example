# Base URL of the FPL Helper API backend.
# Required when the frontend and backend are hosted on different origins
# (e.g. Vercel frontend + Railway backend).
# Leave empty (or omit this file) when they share the same origin — the
# Vite dev proxy handles routing to localhost:8000 automatically.
# Example: https://fpl-helper-api.railway.app
VITE_API_BASE_URL=
